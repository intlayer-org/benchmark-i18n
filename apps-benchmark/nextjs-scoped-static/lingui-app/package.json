{
  "name": "nextjs-scoped-static-lingui-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "compile": "bunx @lingui/cli compile",
    "dev": "next dev",
    "extract": "bunx @lingui/cli extract",
    "lint": "eslint",
    "start": "next start",
    "test": "bun test:pages && bun test:components && bun test:rendering && bun test:reactivity",
    "test:components": "bun scripts/measure-components.ts",
    "test:consistency": "playwright test structure-consistency.test.ts",
    "test:pages": "playwright test pages.test.ts",
    "test:reactivity": "playwright test reactivity.test.ts",
    "test:rendering": "playwright test rendering.test.ts",
    "test:bundle": "next experimental-analyze --output && mkdir -p ../../../results/${npm_package_name}/bundle && cp -r .next/diagnostics/analyze/* ../../../results/${npm_package_name}/bundle/ && mv ../../../results/${npm_package_name}/bundle/index.html ../../../results/${npm_package_name}/bundle/rollup-visualizer.html"
  },
  "dependencies": {
    "@lingui/cli": "^5.9.5",
    "@lingui/core": "^5.3.0",
    "@lingui/format-json": "^5.9.5",
    "@lingui/react": "^5.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "bun": "^1.3.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "test-utils": "workspace:*",
    "typescript": "^5",
    "vite": "^8.0.8"
  }
}
