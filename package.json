{
  "name": "benchmark-bloom",
  "version": "1.0.0",
  "packageManager": "bun@1.3.12",
  "main": "index.js",
  "author": "",
  "license": "ISC",
  "description": "",
  "workspaces": [
    "test-utils",
    "apps-benchmark/nextjs-base-app",
    "apps-benchmark/nextjs-static/*",
    "apps-benchmark/nextjs-dynamic/*",
    "apps-benchmark/nextjs-scoped-static/*",
    "apps-benchmark/nextjs-scoped-dynamic/*",
    "apps-benchmark/tanstack-start-react-base-app",
    "apps-benchmark/tanstack-start-react-static/*",
    "apps-benchmark/tanstack-start-react-dynamic/*",
    "apps-benchmark/tanstack-start-react-scoped-static/*",
    "apps-benchmark/tanstack-start-react-scoped-dynamic/*",
    "apps-benchmark/vite+react-base-app"
  ],
  "scripts": {
    "report": "bun report/scripts/summarize.ts --out report/scripts/summarize --md report/scripts/summarize",
    "build": "turbo run build --concurrency=1 --continue",
    "test": "turbo run test:pages test:rendering test:reactivity test:components test:lib-size test:next test:tanstack --concurrency=1 --continue",
    "test:bundle": "turbo run test:bundle --concurrency=1 --continue",
    "test:pages": "turbo run test:pages --concurrency=1 --continue",
    "test:consistency": "turbo run test:consistency --concurrency=1 --continue",
    "test:rendering": "turbo run test:rendering --concurrency=1 --continue",
    "test:reactivity": "turbo run test:reactivity --concurrency=1 --continue",
    "test:components": "turbo run test:components --concurrency=1 --continue",
    "test:lib-size": "turbo run test:lib-size --concurrency=1 --continue",
    "test:lib-size:next": "turbo run test:lib-size --filter=\"./apps-benchmark/nextjs-static/*\" --concurrency=1 --continue",
    "test:lib-size:tanstack": "turbo run test:lib-size --filter=\"./apps-benchmark/tanstack-start-react-static/*\" --concurrency=1 --continue",
    "test:next": "turbo run test:pages test:rendering test:reactivity test:components test:lib-size --filter=\"nextjs-*\" --concurrency=1 --continue",
    "test:tanstack": "turbo run test:pages test:rendering test:reactivity test:components test:lib-size --filter=\"./apps-benchmark/tanstack-start-react-base-app\" --filter=\"./apps-benchmark/tanstack-start-react-static/*\" --filter=\"./apps-benchmark/tanstack-start-react-dynamic/*\" --filter=\"./apps-benchmark/tanstack-start-react-scoped-static/*\" --filter=\"./apps-benchmark/tanstack-start-react-scoped-dynamic/*\" --concurrency=1 --continue",
    "build:tanstack": "turbo run build --concurrency=1 --filter=\"./apps-benchmark/tanstack-start-react-base-app\" --filter=\"./apps-benchmark/tanstack-start-react-static/*\" --filter=\"./apps-benchmark/tanstack-start-react-dynamic/*\" --filter=\"./apps-benchmark/tanstack-start-react-scoped-static/*\" --filter=\"./apps-benchmark/tanstack-start-react-scoped-dynamic/*\"",
    "build:tanstack:static": "turbo run build --concurrency=1 --filter=\"./apps-benchmark/tanstack-start-react-static/*\" --filter=\"./apps-benchmark/tanstack-start-react-base-app\"",
    "build:tanstack:dynamic": "turbo run build --concurrency=1 --filter=\"./apps-benchmark/tanstack-start-react-dynamic/*\"",
    "build:tanstack:scoped": "turbo run build --concurrency=1 --filter=\"./apps-benchmark/tanstack-start-react-scoped-static/*\" --filter=\"./apps-benchmark/tanstack-start-react-scoped-dynamic/*\"",
    "build:tanstack:scoped:static": "turbo run build --concurrency=1 --filter=\"./apps-benchmark/tanstack-start-react-scoped-static/*\"",
    "build:tanstack:scoped:dynamic": "turbo run build --concurrency=1 --filter=\"./apps-benchmark/tanstack-start-react-scoped-dynamic/*\"",
    "build:nextjs": "turbo run build --concurrency=1 --filter=\"nextjs-*\"",
    "build:nextjs:static": "turbo run build --concurrency=1 --filter=\"nextjs-static\"",
    "build:nextjs:dynamic": "turbo run build --concurrency=1 --filter=\"nextjs-dynamic\"",
    "build:vite+react": "turbo run build --concurrency=1 --filter=\"vite+react-*\"",
    "build:vite+react:static": "turbo run build --concurrency=1 --filter=\"vite+react-static\""
  },
  "dependencies": {
    "@biomejs/biome": "2.4.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "turbo": "^2.9.6"
  }
}
