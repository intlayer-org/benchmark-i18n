{
  "name": "benchmark-bloom",
  "version": "1.0.0",
  "packageManager": "bun@1.3.12",
  "main": "index.js",
  "author": "",
  "license": "ISC",
  "description": "",
  "workspaces": [
    "test-utils",
    "nextjs-static/*",
    "nextjs-dynamic/*",
    "tanstack-start-react-static/*",
    "tanstack-start-react-dynamic/*",
    "tanstack-start-react-scoped-static/*",
    "tanstack-start-react-scoped-dynamic/*",
    "vite+react-static/*"
  ],
  "scripts": {
    "build": "turbo run build --concurrency=1",
    "test": "turbo run test:pages test:reactivity test:components --concurrency=1",
    "test:pages": "turbo run test:pages --concurrency=1",
    "test:consistency": "turbo run test:consistency --concurrency=1",
    "test:reactivity": "turbo run test:reactivity --concurrency=1",
    "test:components": "turbo run test:components --concurrency=1",
    "dev:tanstack": "turbo run dev --filter=\"tanstack-*\"",
    "dev:tanstack:static": "turbo run dev --filter=\"tanstack-start-react-static\"",
    "dev:tanstack:dynamic": "turbo run dev --filter=\"tanstack-start-react-dynamic\"",
    "dev:tanstack:scoped": "turbo run dev --filter=\"tanstack-start-react-scoped-*\"",
    "dev:tanstack:scoped:static": "turbo run dev --filter=\"tanstack-start-react-scoped-static\"",
    "dev:tanstack:scoped:dynamic": "turbo run dev --filter=\"tanstack-start-react-scoped-dynamic\"",
    "dev:nextjs": "turbo run dev --filter=\"nextjs-*\"",
    "dev:nextjs:static": "turbo run dev --filter=\"nextjs-static\"",
    "dev:nextjs:dynamic": "turbo run dev --filter=\"nextjs-dynamic\"",
    "dev:vite+react": "turbo run dev --filter=\"vite+react-*\"",
    "dev:vite+react:static": "turbo run dev --filter=\"vite+react-static\"",
    "build:tanstack": "turbo run build --concurrency=1 --filter=\"tanstack-*\"",
    "build:tanstack:static": "turbo run build --concurrency=1 --filter=\"tanstack-start-react-static\"",
    "build:tanstack:dynamic": "turbo run build --concurrency=1 --filter=\"tanstack-start-react-dynamic\"",
    "build:tanstack:scoped": "turbo run build --concurrency=1 --filter=\"tanstack-start-react-scoped-*\"",
    "build:tanstack:scoped:static": "turbo run build --concurrency=1 --filter=\"tanstack-start-react-scoped-static\"",
    "build:tanstack:scoped:dynamic": "turbo run build --concurrency=1 --filter=\"tanstack-start-react-scoped-dynamic\"",
    "build:nextjs": "turbo run build --concurrency=1 --filter=\"nextjs-*\"",
    "build:nextjs:static": "turbo run build --concurrency=1 --filter=\"nextjs-static\"",
    "build:nextjs:dynamic": "turbo run build --concurrency=1 --filter=\"nextjs-dynamic\"",
    "build:vite+react": "turbo run build --concurrency=1 --filter=\"vite+react-*\"",
    "build:vite+react:static": "turbo run build --concurrency=1 --filter=\"vite+react-static\""
  },
  "dependencies": {
    "biome": "^0.3.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "turbo": "^2.9.6"
  }
}
